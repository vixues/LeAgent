<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened Runtime: allow JIT for Electron's V8 -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow unsigned executable memory (required by Electron / Chromium) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Disable library validation so bundled Python + native extensions load -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Network access for the backend server and LLM API calls -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- File access: the app reads/writes to ~/. leagent and uploads -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
