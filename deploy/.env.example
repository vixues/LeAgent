# =============================================================================
# LeAgent — Docker Compose environment (SQLite-only single container)
# =============================================================================
# Copy to .env and adjust:
#   cp .env.example .env
#
# From this directory:
#   docker compose up -d --build
# Or:  ./run_docker.sh init && ./run_docker.sh up
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
# Application secret (signed URLs, session crypto). Generate:
#   openssl rand -hex 32
LEAGENT_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# -----------------------------------------------------------------------------
# Compose / runtime
# -----------------------------------------------------------------------------
LEAGENT_VERSION=latest
# Host port published for the API (inside container LEAGENT_PORT stays 8000)
LEAGENT_HOST_PORT=8000
# Gunicorn workers — keep 1 for SQLite (single writer)
LEAGENT_WORKERS=1
LEAGENT_LOG_LEVEL=INFO
# Optional: override the Python executable used by code_execution and uv installs.
# LEAGENT_BACKEND_PYTHON=/opt/venv/bin/python

# -----------------------------------------------------------------------------
# LLM (configure at least one provider for chat)
# -----------------------------------------------------------------------------
# On first startup, detected API keys are auto-imported into providers.yaml,
# which becomes the primary configuration store.  Manage providers via the
# Admin UI after initial setup.
#
# If chat fails with "ConnectError: All connection attempts failed" while a
# system proxy (ALL_PROXY / HTTP_PROXY) is set but not running, set:
# LLM_HTTPX_TRUST_ENV=never
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_ENABLE_THINKING=true
# DASHSCOPE_ENABLE_SEARCH=false
#
# vLLM remote or local deployment (OpenAI-compatible /v1 endpoint).
# Example remote DeepSeek vLLM:
# VLLM_ENDPOINT=http://192.168.232.22:8001/v1
# VLLM_MODEL=deepseek
# VLLM_API_KEY=<remote-vllm-api-key>
#
# Leave VLLM_MODEL empty to auto-detect the first model from /v1/models.
# For the optional local GPU overlay, set VLLM_MODEL and run:
#   docker compose -f docker-compose.yml -f docker-compose.vllm.yml up -d --build
# VLLM_ENDPOINT=http://host.docker.internal:9000/v1
# VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
# VLLM_API_KEY=
# VLLM_TIMEOUT=120
# VLLM_VERSION=latest
# VLLM_HOST_PORT=9000
# VLLM_TOOL_CALL_PARSER=llama3_json
# Set true when vLLM is started with --enable-auto-tool-choice (see docker-compose.vllm.yml).
# VLLM_ENABLE_AUTO_TOOL_CHOICE=true
# HUGGING_FACE_HUB_TOKEN=
#
# Ollama local inference (register as named provider "ollama"; set default_provider in providers.yaml).
# LLM_OLLAMA_ENDPOINT=http://localhost:11434
# LLM_OLLAMA_MODEL=llama3.2
# Enable thinking in providers.yaml metadata: thinking: true (maps to Ollama think parameter).

# -----------------------------------------------------------------------------
# Optional: explicit SQLite path (default: /app/data/leagent.db when LEAGENT_HOME=/app/data)
# -----------------------------------------------------------------------------
# DB_SQLITE_PATH=/app/data/leagent.db

# -----------------------------------------------------------------------------
# Optional: CJK fonts for PDF / matplotlib in code_execution
# -----------------------------------------------------------------------------
# LEAGENT_CJK_FONT=/usr/share/fonts/opentype/noto/NotoSansSC-Regular.otf
