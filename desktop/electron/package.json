{
  "name": "leagent-desktop",
  "version": "1.1.3",
  "description": "LeAgent Desktop — local-first intelligent office automation",
  "homepage": "https://github.com/vixues/LeAgent",
  "author": "LeAgent Team",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "electron .",
    "dev": "tsc && electron .",
    "pack:win": "electron-builder --win --x64 --config electron-builder.yml",
    "pack:mac": "electron-builder --mac --arm64 --x64 --config electron-builder.yml",
    "pack:mac-arm64": "electron-builder --mac --arm64 --config electron-builder.yml",
    "pack:mac-x64": "electron-builder --mac --x64 --config electron-builder.yml",
    "pack:linux": "electron-builder --linux --x64 --config electron-builder.yml",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/node": "^22.10.0",
    "electron": "^33.3.1",
    "electron-builder": "^26.10.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  },
  "overrides": {
    "@electron/asar": "^4.2.0",
    "glob": "^13.0.0",
    "rimraf": "^6.0.0"
  }
}
