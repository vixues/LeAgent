# =============================================================================
# LeAgent — Docker Compose environment (SQLite-only single container)
# =============================================================================
# Copy to .env and adjust:
#   cp .env.example .env
#
# From this directory:
#   docker compose up -d --build
# Or:  ./run_docker.sh init && ./run_docker.sh up
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
# Application secret (signed URLs, session crypto). Generate:
#   openssl rand -hex 32
LEAGENT_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# -----------------------------------------------------------------------------
# Compose / runtime
# -----------------------------------------------------------------------------
LEAGENT_VERSION=latest
# Host port published for the API (inside container LEAGENT_PORT stays 8000)
LEAGENT_HOST_PORT=8000
# Gunicorn workers — keep 1 for SQLite (single writer)
LEAGENT_WORKERS=1
LEAGENT_LOG_LEVEL=INFO
# Optional: override the Python executable used by code_execution and uv installs.
# LEAGENT_BACKEND_PYTHON=/opt/venv/bin/python

# -----------------------------------------------------------------------------
# LLM (configure at least one provider for chat)
# -----------------------------------------------------------------------------
# If chat fails with "ConnectError: All connection attempts failed" while a
# system proxy (ALL_PROXY / HTTP_PROXY) is set but not running, set:
# LLM_HTTPX_TRUST_ENV=never
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# DASHSCOPE_API_KEY=

# -----------------------------------------------------------------------------
# Optional: explicit SQLite path (default: /app/data/leagent.db when LEAGENT_HOME=/app/data)
# -----------------------------------------------------------------------------
# DB_SQLITE_PATH=/app/data/leagent.db

# -----------------------------------------------------------------------------
# Optional: CJK fonts for PDF / matplotlib in code_execution
# -----------------------------------------------------------------------------
# LEAGENT_CJK_FONT=/usr/share/fonts/opentype/noto/NotoSansSC-Regular.otf
